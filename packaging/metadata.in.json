{
  "$schema": "https://go.kicad.org/pcm/schemas/v2",
  "name": "KiGit",
  "description": "Git workflows and automation for KiCad projects.",
  "description_full": "KiGit helps manage KiCad projects with Git: initialize repos, commit changes with consistent messages, auto-export manufacturing and review artifacts via kicad-cli, and sync with a remote repository.",
  "identifier": "com.github.ahmed_mek.kigit",
  "type": "plugin",
  "author": {
    "name": "Ahmed Mek",
    "contact": {
      "web": "https://github.com/Ahmed-mek/KiGit"
    }
  },
  "maintainer": {
    "name": "Ahmed Mek",
    "contact": {
      "web": "https://github.com/Ahmed-mek/KiGit"
    }
  },
  "license": "GPL-3.0-or-later",
  "resources": {
    "homepage": "https://github.com/Ahmed-mek/KiGit",
    "documentation": "https://github.com/Ahmed-mek/KiGit#readme",
    "repository": "https://github.com/Ahmed-mek/KiGit",
    "bugtracker": "https://github.com/Ahmed-mek/KiGit/issues"
  },
  "tags": ["git", "version-control", "automation", "kicad-cli"],
  "versions": [
    {
      "version": "0.4.14",
      "status": "stable",
      "kicad_version": "8.0",
      "kicad_version_max": "10.99",
      "runtime": "swig",
      "platforms": ["windows", "macos", "linux"]
    }
  ]
